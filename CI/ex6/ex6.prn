% -------- RULES --------

% Father & Mother
father(X,Y) :- parent(X,Y), male(X).
mother(X,Y) :- parent(X,Y), female(X).

% Child
child(X,Y) :- parent(Y,X).

% Siblings
sibling(X,Y) :-
    parent(P,X),
    parent(P,Y),
    X \= Y.

% Brother & Sister
brother(X,Y) :- sibling(X,Y), male(X).
sister(X,Y) :- sibling(X,Y), female(X).

% Grandparent
grandparent(X,Y) :-
    parent(X,Z),
    parent(Z,Y).

% Husband & Wife (basic assumption)
husband(X,Y) :-
    parent(X,C),
    parent(Y,C),
    male(X),
    X \= Y.

wife(X,Y) :-
    husband(Y,X).

% Uncle & Aunt
uncle(X,Y) :-
    brother(X,Z),
    parent(Z,Y).

aunt(X,Y) :-
    sister(X,Z),
    parent(Z,Y).

% Cousins
cousin(X,Y) :-
    parent(A,X),
    parent(B,Y),
    sibling(A,B),
    X \= Y.


